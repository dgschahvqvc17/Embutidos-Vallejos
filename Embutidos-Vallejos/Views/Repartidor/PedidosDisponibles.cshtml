@model List<Embutidos_Vallejos.Models.DTOs.PedidoDto>
@{
    ViewData["Title"] = "Pedidos Disponibles";
}

<div class="page-header">
    <h1 class="page-title"><i class="fa-solid fa-box-open me-2"></i> Pedidos Disponibles</h1>
    <p class="page-subtitle">Explora todos los pedidos pendientes y selecciona uno para repartir</p>
</div>

@if (TempData["Success"] is string s)
{
    <div class="alert-custom alert-success-custom alert-dismissible fade show" role="alert">@s<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] is string e)
{
    <div class="alert-custom alert-error-custom alert-dismissible fade show" role="alert">@e<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fa-solid fa-box-open"></i>
        <h3>No hay pedidos disponibles</h3>
        <p>Por el momento no hay pedidos pendientes de recoger.</p>
        <a asp-action="Index" class="btn-action btn-action-primary">
            <i class="fa-solid fa-truck-fast me-1"></i> Ver Mis Entregas
        </a>
    </div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="mini-stat">
                <span class="mini-stat-label">Pedidos Disponibles</span>
                <span class="mini-stat-value">@Model.Count</span>
            </div>
        </div>
    </div>

    <div class="table-container">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Cliente</th>
                    <th>Fecha</th>
                    <th>Total</th>
                    <th>Estado</th>
                    <th>Pago</th>
                    <th>Accion</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><strong>#@p.PedidoId</strong></td>
                        <td>@p.NombreCliente</td>
                        <td>@p.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@p.Total.ToString("C", new System.Globalization.CultureInfo("es-BO"))</td>
                        <td>
                            @switch (p.Estado)
                            {
                                case "Pagado": <span class="badge-status status-paid">Pagado</span>; break;
                                case "En Preparacion": <span class="badge-status status-progress">En Preparacion</span>; break;
                                default: <span class="badge-status status-inactive">@p.Estado</span>; break;
                            }
                        </td>
                        <td>
                            @if (p.Pago != null)
                            {
                                <span>@p.Pago.TipoPago</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            <div class="action-btns">
                                <button type="button" class="btn-icon btn-view" title="Ver detalle"
                                        data-bs-toggle="modal" data-bs-target="#detalleModal-@p.PedidoId">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                <form asp-action="TomarPedido" asp-route-pedidoId="@p.PedidoId" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Deseas tomar el pedido #@p.PedidoId? Se asignara a tu nombre y pasara a estado En Preparacion.')">
                                    <button type="submit" class="btn-action btn-action-primary btn-sm">
                                        <i class="fa-solid fa-hand me-1"></i> Tomar
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @foreach (var p in Model)
    {
        <div class="modal fade" id="detalleModal-@p.PedidoId" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content modal-dark">
                    <div class="modal-header">
                        <h5 class="modal-title">Pedido #@p.PedidoId - @p.NombreCliente</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="info-label">Cliente</div>
                                <div class="info-value">@p.NombreCliente</div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-label">Fecha</div>
                                <div class="info-value">@p.FechaPedido.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-label">Direccion de Entrega</div>
                                <div class="info-value">@(p.DireccionEntrega ?? "-")</div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-label">Total</div>
                                <div class="info-value" style="color:var(--accent);font-weight:700;">@p.Total.ToString("C", new System.Globalization.CultureInfo("es-BO"))</div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-label">Estado</div>
                                <div class="info-value">
                                    @switch (p.Estado)
                                    {
                                        case "Pagado": <span class="badge-status status-paid">Pagado</span>; break;
                                        case "En Preparacion": <span class="badge-status status-progress">En Preparacion</span>; break;
                                        default: <span class="badge-status status-inactive">@p.Estado</span>; break;
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-label">Pago</div>
                                <div class="info-value">@(p.Pago?.TipoPago ?? "-")</div>
                            </div>
                        </div>

                        @if (p.Detalles.Any())
                        {
                            <div class="info-label mb-2">Productos</div>
                            <div class="table-detalle">
                                <table class="detail-table">
                                    <thead>
                                        <tr>
                                            <th>Producto</th>
                                            <th>Cant.</th>
                                            <th>P. Unitario</th>
                                            <th>Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in p.Detalles)
                                        {
                                            <tr>
                                                <td>@d.NombreProducto</td>
                                                <td>@d.Cantidad</td>
                                                <td>@d.PrecioUnitario.ToString("C", new System.Globalization.CultureInfo("es-BO"))</td>
                                                <td style="color:var(--accent);font-weight:600;">@d.Subtotal.ToString("C", new System.Globalization.CultureInfo("es-BO"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cerrar</button>
                        <form asp-action="TomarPedido" asp-route-pedidoId="@p.PedidoId" method="post" class="d-inline">
                            <button type="submit" class="btn-submit-sm">
                                <i class="fa-solid fa-hand me-1"></i> Tomar Pedido
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}

@section Scripts {

}
