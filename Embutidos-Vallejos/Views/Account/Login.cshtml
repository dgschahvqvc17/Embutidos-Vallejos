@model LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesion - Embutidos Vallejos</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #7A1F2A; --accent: #C9A94E; --bg-body: #0B0C10; --bg-card: #15161C; --bg-input: #1E1F28; --border-color: #262838; --text-primary: #E8E8EE; --text-secondary: #8A8B9E; --text-muted: #55566A; --danger: #FF1744; --font-display: 'Playfair Display', serif; --font-body: 'Inter', sans-serif; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-body); min-height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; overflow-x: hidden; }
        .video-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; }
        .video-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(10,11,15,0.75) 0%, rgba(0,0,0,0.55) 50%, rgba(10,11,15,0.7) 100%); z-index: -1; }
        .back-home { position: fixed; top: 24px; left: 24px; z-index: 10; }
        .back-home a { display: inline-flex; align-items: center; gap: 6px; color: rgba(232,232,238,0.5); text-decoration: none; font-size: 13px; font-weight: 500; padding: 8px 16px; border-radius: 6px; background: rgba(21,22,28,0.6); border: 1px solid rgba(38,40,56,0.5); backdrop-filter: blur(10px); transition: all 0.25s ease; }
        .back-home a:hover { color: var(--accent); border-color: var(--accent); transform: translateX(-3px); }
        .login-container { width: 100%; max-width: 400px; padding: 20px; position: relative; z-index: 1; }
        .login-card { background: rgba(21,22,28,0.85); border: 1px solid rgba(38,40,56,0.6); border-radius: 12px; padding: 36px 32px 28px; backdrop-filter: blur(20px); }
        .logo-section { text-align: center; margin-bottom: 28px; }
        .logo-title { font-family: var(--font-display); font-weight: 900; font-size: 24px; color: var(--text-primary); letter-spacing: -0.3px; line-height: 1.2; }
        .logo-title span { color: var(--accent); }
        .logo-subtitle { color: rgba(232,232,238,0.35); font-size: 10px; letter-spacing: 4px; text-transform: uppercase; margin-top: 4px; }
        .form-label { color: rgba(232,232,238,0.4); font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 4px; }
        .form-control { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 6px; padding: 11px 14px; padding-left: 42px; color: #ffffff; font-size: 15px; transition: all 0.25s ease; height: 46px; width: 100%; }
        .form-control:focus { background: rgba(255,255,255,0.08); border-color: var(--accent); box-shadow: 0 0 0 2px rgba(201,169,78,0.15); outline: none; color: #ffffff; }
        .form-control::placeholder { color: rgba(255,255,255,0.25); }
        .form-control:-webkit-autofill, .form-control:-webkit-autofill:hover, .form-control:-webkit-autofill:focus { -webkit-text-fill-color: #ffffff !important; -webkit-box-shadow: 0 0 0px 1000px rgba(42,44,58,0.9) inset !important; transition: background-color 5000s ease-in-out 0s; caret-color: #ffffff; }
        .input-group { position: relative; }
        .input-icon { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.25); font-size: 15px; z-index: 4; pointer-events: none; }
        .toggle-password { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.25); background: none; border: none; cursor: pointer; font-size: 15px; padding: 6px; z-index: 4; transition: color 0.2s; }
        .toggle-password:hover { color: rgba(255,255,255,0.5); }
        .btn-login { background: var(--primary); border: 1px solid var(--primary); border-radius: 6px; padding: 13px; font-size: 14px; font-weight: 600; color: #fff; width: 100%; transition: all 0.25s ease; letter-spacing: 0.3px; cursor: pointer; }
        .btn-login:hover { background: #8E2633; border-color: #8E2633; }
        .form-check-label { color: rgba(232,232,238,0.4); font-size: 13px; cursor: pointer; user-select: none; }
        .form-check-input { background-color: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.08); width: 16px; height: 16px; cursor: pointer; margin-top: 0; }
        .form-check-input:checked { background-color: var(--primary); border-color: var(--primary); }
        .text-validation { color: var(--danger); font-size: 11px; margin-top: 4px; display: block; }
        .alert-danger { background: rgba(255,23,68,0.08); border: 1px solid rgba(255,23,68,0.15); border-radius: 6px; color: var(--danger); font-size: 12px; padding: 10px 14px; margin-bottom: 18px; }
        .alert-danger ul { list-style: none; padding: 0; margin: 0; }
        .divider { display: flex; align-items: center; gap: 14px; margin: 22px 0; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.06); }
        .divider span { color: rgba(232,232,238,0.25); font-size: 10px; text-transform: uppercase; letter-spacing: 2px; }
        .register-link { text-align: center; margin-top: 18px; }
        .register-link span { color: rgba(232,232,238,0.4); font-size: 13px; }
        .register-link a { color: var(--accent); text-decoration: none; font-weight: 600; margin-left: 4px; transition: color 0.2s; }
        .register-link a:hover { color: var(--accent); text-decoration: underline; }
        .footer-text { text-align: center; margin-top: 18px; color: rgba(232,232,238,0.2); font-size: 10px; }
        .mb-4-custom { margin-bottom: 16px; }
        @@media (max-width: 480px) { .login-card { padding: 28px 20px 22px; } .back-home { top: 16px; left: 16px; } .back-home a { font-size: 11px; padding: 6px 12px; } }
    </style>
</head>
<body>
    <video class="video-bg" autoplay muted loop playsinline>
        <source src="~/video/video1.mp4" type="video/mp4" />
    </video>
    <div class="video-overlay"></div>

    <div class="back-home">
        <a asp-controller="Home" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Volver al inicio</a>
    </div>
    <div class="login-container">
        <div class="login-card">
            <div class="logo-section">
                <div class="logo-title">Embutidos <span>Vallejos</span></div>
                <div class="logo-subtitle">Sabor que trasciende</div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-danger"><div asp-validation-summary="ModelOnly"></div></div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-4-custom">
                    <label asp-for="Email" class="form-label"><i class="fa-regular fa-envelope me-1"></i> @Html.DisplayNameFor(m => m.Email)</label>
                    <div class="input-group">
                        <i class="fa-regular fa-envelope input-icon"></i>
                        <input asp-for="Email" class="form-control" placeholder="tu@correo.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-validation"></span>
                </div>
                <div class="mb-4-custom">
                    <label asp-for="Password" class="form-label"><i class="fa-solid fa-lock me-1"></i> @Html.DisplayNameFor(m => m.Password)</label>
                    <div class="input-group">
                        <i class="fa-solid fa-lock input-icon"></i>
                        <input asp-for="Password" class="form-control" id="password" placeholder="Tu contrasena" />
                        <button type="button" class="toggle-password" onclick="togglePassword()"><i class="fa-regular fa-eye" id="toggleIcon"></i></button>
                    </div>
                    <span asp-validation-for="Password" class="text-validation"></span>
                </div>
                <div class="mb-4-custom d-flex justify-content-between align-items-center">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                </div>
                <button type="submit" class="btn-login"><i class="fa-regular fa-arrow-right-to-bracket me-2"></i> Iniciar Sesion</button>
            </form>

            <div class="divider"><span>O</span></div>

            <div class="register-link">
                <span>¿No tienes cuenta?</span>
                <a asp-controller="Account" asp-action="Register">Crea una aqui <i class="fa-solid fa-arrow-right ms-1" style="font-size: 11px;"></i></a>
            </div>

            <div class="footer-text">&copy; 2026 Embutidos Vallejos &mdash; Todos los derechos reservados</div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePassword() {
            const input = document.getElementById('password');
            const icon = document.getElementById('toggleIcon');
            if (input.type === 'password') { input.type = 'text'; icon.classList.replace('fa-eye', 'fa-eye-slash'); }
            else { input.type = 'password'; icon.classList.replace('fa-eye-slash', 'fa-eye'); }
        }
    </script>
</body>
</html>
