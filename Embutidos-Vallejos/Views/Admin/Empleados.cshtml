@model List<Embutidos_Vallejos.Models.DTOs.EmpleadoDto>
@{
    ViewData["Title"] = "Gestion de Empleados";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="admin-title">Empleados</h1>
        <p class="admin-subtitle">Gestion del personal de la empresa</p>
    </div>
    <a asp-action="CrearEmpleado" class="btn btn-primary-custom">
        <i class="fa-solid fa-user-plus me-2"></i> Nuevo Empleado
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-custom alert-success-custom">@TempData["Success"]</div>
}

<div class="table-container">
    <table class="table-custom">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Email</th>
                <th>Telefono</th>
                <th>Rol</th>
                <th>Estado</th>
                <th>Contratacion</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.EmpleadoId</td>
                    <td><strong>@emp.Nombre @emp.Apellido</strong></td>
                    <td>@emp.Email</td>
                    <td>@(emp.Telefono ?? "-")</td>
                    <td><span class="badge-role">@emp.NombreRol</span></td>
                    <td>
                        @if (emp.Estado == "Activo")
                        {
                            <span class="badge-status status-active">Activo</span>
                        }
                        else
                        {
                            <span class="badge-status status-inactive">@emp.Estado</span>
                        }
                    </td>
                    <td>@emp.FechaContratacion.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="action-btns">
                            <a asp-action="EditarEmpleado" asp-route-id="@emp.EmpleadoId" class="btn-icon btn-edit" title="Editar">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <form asp-action="EliminarEmpleado" asp-route-id="@emp.EmpleadoId" method="post" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar empleado @emp.Nombre @emp.Apellido?')">
                                <button type="submit" class="btn-icon btn-delete" title="Eliminar">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {

}
