@model Embutidos_Vallejos.Models.DTOs.DashboardDto
@{
    ViewData["Title"] = "Panel de Administracion";
}

<div class="admin-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="admin-title" style="color:#ffffff;">Panel de Administracion</h1>
            <p class="admin-subtitle" style="color:rgba(255,255,255,0.85);">Bienvenido al sistema de gestion @(User.Identity?.Name ?? "Administrador")</p>
        </div>
        <div class="text-end">
            <span class="badge-dashboard" style="color:#ffffff;">@DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("es-BO"))</span>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3 col-6">
        <div class="stat-card stat-red">
            <div class="stat-icon"><i class="bi bi-box"></i></div>
            <div class="stat-info">
                <h3 style="color:#ffffff;">@Model.TotalProductos</h3>
                <p style="color:rgba(255,255,255,0.9);">Productos</p>
            </div>
            <div class="stat-trend">
                @if (Model.ProductosStockBajo > 0)
                {
                    <span class="text-warning"><i class="bi bi-exclamation-triangle"></i> @Model.ProductosStockBajo stock bajo</span>
                }
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card stat-gold">
            <div class="stat-icon"><i class="bi bi-truck"></i></div>
            <div class="stat-info">
                <h3 style="color:#ffffff;">@Model.TotalPedidos</h3>
                <p style="color:rgba(255,255,255,0.9);">Pedidos totales</p>
            </div>
            <div class="stat-trend">
                <span class="text-warning"><i class="bi bi-clock"></i> @Model.PedidosPendientes pendientes</span>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card stat-green">
            <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
            <div class="stat-info">
                <h3 style="color:#ffffff;">@Model.PedidosEntregados</h3>
                <p style="color:rgba(255,255,255,0.9);">Entregados</p>
            </div>
            <div class="stat-trend">
                <span class="text-success" style="filter: brightness(1.2);"><i class="bi bi-check"></i> Completados</span>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card stat-blue">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="stat-info">
                <h3 style="color:#ffffff;">@Model.TotalClientes</h3>
                <p style="color:rgba(255,255,255,0.9);">Clientes</p>
            </div>
            <div class="stat-trend">
                <span style="color:rgba(255,255,255,0.85);"><i class="bi bi-person-badge"></i> @Model.TotalEmpleados empleados</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card-admin">
            <div class="card-admin-header">
                <h5 style="color:#ffffff;"><i class="bi bi-graph-up me-2"></i> Ventas</h5>
            </div>
            <div class="card-admin-body text-center py-4">
                <div class="row">
                    <div class="col-6">
                        <div class="metric-box">
                            <div class="metric-value text-gold" style="filter: brightness(1.2);">@Model.VentasHoy.ToString("C", new System.Globalization.CultureInfo("es-BO"))</div>
                            <div class="metric-label" style="color:rgba(255,255,255,0.9);">Ventas Hoy</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="metric-box">
                            <div class="metric-value text-red" style="filter: brightness(1.2);">@Model.VentasMes.ToString("C", new System.Globalization.CultureInfo("es-BO"))</div>
                            <div class="metric-label" style="color:rgba(255,255,255,0.9);">Ventas del Mes</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card-admin">
            <div class="card-admin-header">
                <h5 style="color:#ffffff;"><i class="bi bi-lightning-charge me-2"></i> Acciones Rapidas</h5>
            </div>
            <div class="card-admin-body">
                <div class="quick-actions">
                    <a asp-action="CrearProducto" class="quick-action-btn" style="color:rgba(255,255,255,0.9);">
                        <i class="bi bi-plus-lg"></i> Nuevo Producto
                    </a>
                    <a asp-action="CrearEmpleado" class="quick-action-btn" style="color:rgba(255,255,255,0.9);">
                        <i class="bi bi-person-plus"></i> Nuevo Empleado
                    </a>
                    <a asp-action="Pedidos" class="quick-action-btn" style="color:rgba(255,255,255,0.9);">
                        <i class="bi bi-list-ul"></i> Ver Pedidos
                    </a>
                    <a asp-action="Reportes" class="quick-action-btn" style="color:rgba(255,255,255,0.9);">
                        <i class="bi bi-bar-chart"></i> Reportes
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

}
