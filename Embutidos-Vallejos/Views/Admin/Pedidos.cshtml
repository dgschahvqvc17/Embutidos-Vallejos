@model List<Embutidos_Vallejos.Models.DTOs.PedidoDto>
@{
    ViewData["Title"] = "Gestion de Pedidos";
    var estados = new[] { "Todos", "Pendiente", "Pagado", "En Preparacion", "En Camino", "Entregado", "Cancelado" };
    var estadoActual = ViewBag.EstadoFiltro as string ?? "Todos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="admin-title">Pedidos</h1>
        <p class="admin-subtitle">Gestion de pedidos de clientes</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-custom alert-success-custom">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-custom alert-error-custom">@TempData["Error"]</div>
}

<div class="filter-tabs mb-4">
    @foreach (var est in estados)
    {
        <a asp-action="Pedidos" asp-route-estado="@est"
           class="filter-tab @(estadoActual == est ? "active" : "")">
            @est
        </a>
    }
</div>

<div class="table-container">
    <table class="table-custom">
        <thead>
            <tr>
                <th>#</th>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Estado</th>
                <th>Pago</th>
                <th>Repartidor</th>
                <th>Accion</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td><strong>#@p.PedidoId</strong></td>
                    <td>@p.NombreCliente</td>
                    <td>@p.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@p.Total.ToString("C", new System.Globalization.CultureInfo("es-BO"))</td>
                    <td>
                        @switch (p.Estado)
                        {
                            case "Pendiente": <span class="badge-status status-pending">Pendiente</span>; break;
                            case "Pagado": <span class="badge-status status-paid">Pagado</span>; break;
                            case "En Preparacion": <span class="badge-status status-progress">En Preparacion</span>; break;
                            case "En Camino": <span class="badge-status status-shipping">En Camino</span>; break;
                            case "Entregado": <span class="badge-status status-active">Entregado</span>; break;
                            case "Cancelado": <span class="badge-status status-inactive">Cancelado</span>; break;
                            default: <span class="badge-status status-inactive">@p.Estado</span>; break;
                        }
                    </td>
                    <td>
                        @if (p.Pago != null)
                        {
                            <span>@p.Pago.TipoPago</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>@(p.NombreRepartidor ?? "-")</td>
                    <td>
                        <a asp-action="DetallePedido" asp-route-id="@p.PedidoId" class="btn-icon btn-view" title="Ver detalle">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center py-4 text-muted">No hay pedidos</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {

}
