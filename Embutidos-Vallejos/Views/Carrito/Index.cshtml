@model List<Embutidos_Vallejos.Models.DTOs.CarritoItemDto>
@{
    ViewData["Title"] = "Carrito de Compras";
}

<div class="page-header">
    <h1 class="page-title">Carrito de Compras</h1>
</div>

@if (!Model.Any())
{
    <div class="empty-state glass-panel" style="text-align:center; padding: 60px 40px; border-radius: var(--radius-lg);">
        <i class="fa-solid fa-cart-shopping empty-icon" style="font-size:64px; color:var(--accent); opacity:0.5; margin-bottom:24px; display:block;"></i>
        <h3 style="font-family:var(--font-display); font-size:22px; font-weight:700; margin-bottom:8px;">Tu carrito esta vacio</h3>
        <p style="color:var(--text-secondary); margin-bottom:28px;">Agrega productos desde nuestro catalogo</p>
        <a asp-controller="Producto" asp-action="Index" class="btn-premium btn-empty">
            <i class="fa-solid fa-store me-2"></i> Ver Productos
        </a>
    </div>
}
else
{
    <div class="cart-layout">
        <div class="cart-items">
            @foreach (var item in Model)
            {
                <div class="cart-item glass-panel-light animate-fade-up" data-id="@item.ProductoId" style="transition: transform 0.3s ease, opacity 0.3s ease;">
                    <img src="@(item.ImagenProducto ?? "/img/LogoVallejos.png")" alt="@item.NombreProducto" class="cart-item-img" />
                    <div class="cart-item-info">
                        <div>
                            <h4 class="cart-item-name">@(string.IsNullOrEmpty(item.NombreProducto) ? $"Producto #{item.ProductoId}" : item.NombreProducto)</h4>
                            <p class="cart-item-price">@item.PrecioUnitario.ToString("C", new System.Globalization.CultureInfo("es-BO")) c/u</p>
                        </div>
                    </div>
                    <div class="cart-item-qty">
                        <button class="qty-btn" onclick="updateQty(@item.ProductoId, -1)"><i class="fa-solid fa-minus"></i></button>
                        <span class="qty-value">@item.Cantidad</span>
                        <button class="qty-btn" onclick="updateQty(@item.ProductoId, 1)"><i class="fa-solid fa-plus"></i></button>
                    </div>
                    <div class="cart-item-subtotal">
                        <span class="subtotal-value">@((item.Cantidad * item.PrecioUnitario).ToString("C", new System.Globalization.CultureInfo("es-BO")))</span>
                    </div>
                    <button class="cart-item-remove" onclick="removeItem(@item.ProductoId)" title="Eliminar">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </div>
            }
        </div>

        <div class="cart-summary glass-panel" style="position:sticky; top: 90px;">
            <h4 style="font-family:var(--font-display); font-size:18px; font-weight:700; margin-bottom:20px; color:var(--text-primary);"><i class="fa-solid fa-receipt me-2" style="color:var(--accent);"></i>Resumen</h4>
            <div class="summary-row">
                <span>Subtotal</span>
                <span id="summarySubtotal">@Model.Sum(i => i.Cantidad * i.PrecioUnitario).ToString("C", new System.Globalization.CultureInfo("es-BO"))</span>
            </div>
            <div class="summary-row">
                <span>Productos</span>
                <span id="summaryCount">@Model.Sum(i => i.Cantidad) unidades</span>
            </div>
            <hr class="summary-divider" />
            <div class="summary-row summary-total">
                <span>Total</span>
                <span id="summaryTotal" style="color:var(--accent); font-size:22px;">@Model.Sum(i => i.Cantidad * i.PrecioUnitario).ToString("C", new System.Globalization.CultureInfo("es-BO"))</span>
            </div>
            <a asp-controller="Pedido" asp-action="Checkout" class="btn-premium btn-checkout" style="width:100%; margin-top:16px; justify-content:center; font-size:15px; padding:14px;">
                <i class="fa-regular fa-credit-card"></i> Proceder al Pago
            </a>
            <a asp-controller="Producto" asp-action="Index" class="btn-continue" style="display:block; text-align:center; margin-top:12px;">
                <i class="fa-solid fa-store me-1"></i> Seguir Comprando
            </a>
        </div>
    </div>
}

@section Scripts {
    <script>
        function updateQty(productoId, delta) {
            const item = document.querySelector(`.cart-item[data-id="${productoId}"]`);
            const qtySpan = item.querySelector('.qty-value');
            let qty = parseInt(qtySpan.textContent) + delta;
            if (qty < 1) qty = 1;

            fetch('@Url.Action("ActualizarCantidad", "Carrito")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `productoId=${productoId}&cantidad=${qty}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    qtySpan.textContent = qty;
                    document.getElementById('summarySubtotal').textContent = data.total.toLocaleString('es-BO', { style: 'currency', currency: 'BOB' });
                    document.getElementById('summaryTotal').textContent = data.total.toLocaleString('es-BO', { style: 'currency', currency: 'BOB' });
                    document.getElementById('summaryCount').textContent = data.count + ' unidades';
                    item.querySelector('.subtotal-value').textContent = data.subtotal.toLocaleString('es-BO', { style: 'currency', currency: 'BOB' });
                    if (qty === 0) item.remove();
                }
            });
        }

        function removeItem(productoId) {
            fetch('@Url.Action("Eliminar", "Carrito")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `productoId=${productoId}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    const item = document.querySelector(`.cart-item[data-id="${productoId}"]`);
                    item.style.transform = 'translateX(100px)';
                    item.style.opacity = '0';
                    setTimeout(() => {
                        item.remove();
                        document.getElementById('summarySubtotal').textContent = data.total.toLocaleString('es-BO', { style: 'currency', currency: 'USD' });
                        document.getElementById('summaryTotal').textContent = data.total.toLocaleString('es-BO', { style: 'currency', currency: 'USD' });
                        document.getElementById('summaryCount').textContent = data.count + ' unidades';
                        if (!document.querySelector('.cart-item')) location.reload();
                    }, 300);
                }
            });
        }
    </script>

}
