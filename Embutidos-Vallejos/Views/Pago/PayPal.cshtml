@model Embutidos_Vallejos.Models.DTOs.PedidoDto
@{
    ViewData["Title"] = "Pago con PayPal";
}

<div class="page-header text-center">
    <h1 class="page-title">Pago con PayPal</h1>
    <p class="page-subtitle">Pedido #@Model.PedidoId - Total: @Model.Total.ToString("C", new System.Globalization.CultureInfo("en-US"))</p>
</div>

<div class="paypal-container">
    <div class="paypal-card">
        <div class="paypal-logo">
            <i class="fa-brands fa-paypal" style="font-size:48px;color:#009cde;"></i>
        </div>
        <p class="paypal-desc">
            Completa el pago de <strong>@Model.Total.ToString("C", new System.Globalization.CultureInfo("en-US"))</strong> con tu cuenta de PayPal
        </p>
        <div id="paypal-button-container" class="mt-4"></div>
        <div id="paypal-loading" style="display:none;" class="mt-3">
            <div class="paypal-spinner">
                <i class="fa-solid fa-spinner fa-spin fa-2x" style="color:#009cde;"></i>
                <p class="mt-2">Procesando pago...</p>
            </div>
        </div>
        <div id="paypal-error" style="display:none;" class="mt-3">
            <div class="alert-custom alert-error-custom" id="paypal-error-msg"></div>
            <button class="btn-paypal mt-2" onclick="location.reload()">
                <i class="fa-solid fa-rotate me-2"></i> Reintentar
            </button>
        </div>
        <a asp-controller="Pedido" asp-action="Details" asp-route-id="@Model.PedidoId" class="btn-cancel-paypal mt-3">
            Cancelar y volver al pedido
        </a>
    </div>
</div>

@section Scripts {
    <script src="https://www.paypal.com/sdk/js?client-id=@ViewBag.PayPalClientId&currency=USD&disable-funding=credit,paylater,card"
            data-sdk-integration-source="button-factory"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loading = document.getElementById('paypal-loading');
            const errorDiv = document.getElementById('paypal-error');
            const errorMsg = document.getElementById('paypal-error-msg');

            paypal.Buttons({
                createOrder: function() {
                    loading.style.display = 'block';
                    errorDiv.style.display = 'none';
                    return fetch('@Url.Action("CrearOrdenPayPal", "Pago")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'pedidoId=@Model.PedidoId'
                    })
                    .then(function(res) { return res.json(); })
                    .then(function(data) {
                        if (data.success) {
                            return data.orderId;
                        }
                        throw new Error(data.message || 'Error al crear la orden');
                    });
                },
                onApprove: function(data) {
                    loading.style.display = 'block';
                    errorDiv.style.display = 'none';
                    return fetch('@Url.Action("CapturarOrdenPayPal", "Pago")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'pedidoId=@Model.PedidoId&orderId=' + data.orderID
                    })
                    .then(function(res) { return res.json(); })
                    .then(function(capturaData) {
                        if (capturaData.success) {
                            window.location.href = capturaData.redirect;
                        } else {
                            errorMsg.textContent = capturaData.message || 'Error al capturar el pago';
                            errorDiv.style.display = 'block';
                            loading.style.display = 'none';
                        }
                    });
                },
                onCancel: function() {
                    loading.style.display = 'none';
                    errorMsg.textContent = 'Pago cancelado por el usuario.';
                    errorDiv.style.display = 'block';
                },
                onError: function(err) {
                    loading.style.display = 'none';
                    errorMsg.textContent = 'Error en PayPal: ' + (err.message || err);
                    errorDiv.style.display = 'block';
                }
            }).render('#paypal-button-container');
        });
    </script>
}
