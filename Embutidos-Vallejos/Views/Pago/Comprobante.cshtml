@model Embutidos_Vallejos.Models.DTOs.PagoReceiptDto
@{
    ViewData["Title"] = $"Comprobante Pedido #{Model.PedidoId}";
}

<style>
    .receipt-page { max-width: 620px; margin: 0 auto; padding: 20px 0 60px; }

    /* Top action bar */
    .receipt-actions {
        display: flex; align-items: center; gap: 12px; margin-bottom: 28px;
    }
    .btn-print {
        display: inline-flex; align-items: center; gap: 8px;
        background: var(--primary); color: #fff;
        border: 1px solid var(--primary); border-radius: var(--radius-sm);
        padding: 9px 18px; font-size: 13px; font-weight: 600;
        cursor: pointer; transition: all 0.25s ease; text-decoration: none;
    }
    .btn-print:hover { background: var(--primary-hover); transform: translateY(-1px); box-shadow: var(--shadow-glow); }
    .btn-back-receipt {
        display: inline-flex; align-items: center; gap: 8px;
        background: transparent; color: var(--text-secondary);
        border: 1px solid var(--border-color); border-radius: var(--radius-sm);
        padding: 9px 18px; font-size: 13px; font-weight: 500;
        text-decoration: none; transition: all 0.25s ease;
    }
    .btn-back-receipt:hover { border-color: var(--accent); color: var(--accent); }

    /* The main receipt card */
    .receipt-card {
        background: linear-gradient(160deg, rgba(26,27,36,0.95) 0%, rgba(15,16,20,0.98) 100%);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.5), 0 0 0 1px rgba(201,169,78,0.06);
        animation: fadeUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        opacity: 0; transform: translateY(20px);
    }

    /* Colorful top stripe */
    .receipt-card::before {
        content: '';
        display: block; height: 4px;
        background: linear-gradient(90deg, var(--primary) 0%, var(--accent) 50%, var(--primary) 100%);
    }

    /* Header section */
    .receipt-header {
        padding: 36px 40px 28px;
        text-align: center;
        background: radial-gradient(ellipse at 50% 0%, rgba(201,169,78,0.06) 0%, transparent 70%);
        border-bottom: 1px dashed rgba(255,255,255,0.08);
        position: relative;
    }
    .receipt-success-icon {
        width: 64px; height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(0,200,83,0.15), rgba(0,200,83,0.05));
        border: 2px solid rgba(0,200,83,0.3);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 20px;
        font-size: 26px; color: var(--success);
        animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.4s forwards;
        opacity: 0; transform: scale(0.5);
    }
    @@keyframes popIn { to { opacity: 1; transform: scale(1); } }
    .receipt-logo { height: 40px; margin-bottom: 8px; }
    .receipt-header h1 {
        font-family: var(--font-display);
        font-size: 22px; font-weight: 900;
        color: var(--text-primary); margin: 0 0 4px;
        letter-spacing: -0.3px;
    }
    .receipt-subtitle { color: var(--text-muted); font-size: 11px; letter-spacing: 3px; text-transform: uppercase; margin: 0 0 16px; }
    .receipt-type {
        display: inline-block;
        background: var(--accent-light);
        border: 1px solid rgba(201,169,78,0.2);
        color: var(--accent);
        font-size: 10px; font-weight: 800;
        letter-spacing: 2px; text-transform: uppercase;
        padding: 4px 16px; border-radius: 20px;
    }

    /* Body */
    .receipt-body { padding: 28px 40px; }

    .receipt-info-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 0;
        border: 1px solid var(--border-color); border-radius: var(--radius-md);
        overflow: hidden; margin-bottom: 20px;
    }
    .receipt-info-item {
        padding: 12px 16px;
        border-right: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
        display: flex; flex-direction: column; gap: 3px;
    }
    .receipt-info-item:nth-child(even) { border-right: none; }
    .receipt-info-item.full-width { grid-column: 1 / -1; border-right: none; }
    .receipt-info-item:last-child, .receipt-info-item:nth-last-child(2):not(.full-width) { border-bottom: none; }
    .receipt-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); }
    .receipt-value { font-size: 14px; font-weight: 600; color: var(--text-primary); }

    /* Payment info */
    .receipt-payment-info {
        display: flex; align-items: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;
    }
    .payment-badge {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 5px 14px; border-radius: 20px;
        font-size: 12px; font-weight: 700;
        border: 1px solid transparent;
    }
    .qr-badge { background: rgba(41,121,255,0.1); color: var(--info); border-color: rgba(41,121,255,0.2); }
    .paypal-badge { background: rgba(0,112,243,0.1); color: #339af0; border-color: rgba(0,112,243,0.2); }
    .stripe-badge { background: rgba(99,91,255,0.1); color: #635bff; border-color: rgba(99,91,255,0.25); }
    .cash-badge { background: rgba(0,200,83,0.1); color: var(--success); border-color: rgba(0,200,83,0.2); }
    .payment-status {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 14px; border-radius: 20px;
        font-size: 12px; font-weight: 700;
        border: 1px solid transparent;
    }
    .status-completed { background: var(--success-light); color: var(--success); border-color: rgba(0,200,83,0.2); }
    .status-completed::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--success); display: inline-block; }
    .status-pending { background: var(--warning-light); color: var(--warning); border-color: rgba(255,214,0,0.2); }

    /* Transaction ID */
    .receipt-transaction {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        padding: 10px 16px; margin-bottom: 16px;
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
    }
    .receipt-transaction-id {
        font-family: 'Courier New', monospace;
        font-size: 12px; color: var(--accent);
        letter-spacing: 1px; font-weight: 600;
        word-break: break-all;
    }

    /* Products table */
    .receipt-table { width: 100%; border-collapse: collapse; margin-bottom: 0; }
    .receipt-table th {
        text-align: left; padding: 10px 14px;
        font-size: 10px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.8px; color: var(--text-muted);
        background: rgba(255,255,255,0.02);
        border-bottom: 1px solid var(--border-color);
    }
    .receipt-table th:last-child { text-align: right; }
    .receipt-table td {
        padding: 11px 14px; font-size: 13px;
        color: var(--text-secondary); border-bottom: 1px solid rgba(255,255,255,0.04);
        vertical-align: middle;
    }
    .receipt-table td:last-child { text-align: right; font-weight: 600; color: var(--text-primary); }
    .receipt-table tr:last-child td { border-bottom: none; }

    .table-wrapper {
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md); overflow: hidden; margin-bottom: 0;
    }

    /* Total */
    .receipt-total {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px;
        background: linear-gradient(135deg, rgba(201,169,78,0.08), rgba(201,169,78,0.03));
        border: 1px solid rgba(201,169,78,0.15);
        border-top: none; border-radius: 0 0 var(--radius-md) var(--radius-md);
        margin-bottom: 20px;
    }
    .receipt-total > span:first-child {
        font-size: 11px; font-weight: 800; text-transform: uppercase;
        letter-spacing: 1.5px; color: var(--text-muted);
    }
    .receipt-total-value {
        font-family: var(--font-display);
        font-size: 28px; font-weight: 900;
        color: var(--accent);
        text-shadow: 0 0 20px rgba(201,169,78,0.3);
    }

    /* QR */
    .receipt-qr { text-align: center; margin-bottom: 24px; }
    .qr-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
    .receipt-qr-img { width: 120px; height: 120px; border-radius: var(--radius-sm); border: 2px solid var(--border-color); }

    /* Divider with logo */
    .receipt-divider {
        display: flex; align-items: center; gap: 16px;
        padding: 0 40px; margin: 4px 0;
    }
    .receipt-divider::before, .receipt-divider::after {
        content: ''; flex: 1; height: 1px;
        background: repeating-linear-gradient(90deg, var(--border-color) 0px, var(--border-color) 6px, transparent 6px, transparent 12px);
    }
    .receipt-divider-icon { color: var(--text-muted); font-size: 12px; flex-shrink: 0; }

    /* Footer */
    .receipt-footer {
        padding: 24px 40px 32px; text-align: center;
        background: radial-gradient(ellipse at 50% 100%, rgba(122,31,42,0.05) 0%, transparent 70%);
    }
    .receipt-footer > p:first-child {
        font-family: var(--font-display);
        font-size: 18px; font-weight: 700;
        color: var(--text-primary); margin: 0 0 6px;
    }
    .receipt-footer-text { font-size: 11px; color: var(--text-muted); margin: 2px 0; }

    @@media print {
        .no-print { display: none !important; }
        body { background: #fff !important; color: #000 !important; }
        .receipt-card { box-shadow: none !important; border: 1px solid #ddd !important; background: #fff !important; color: #000 !important; }
        .receipt-card::before { display: none; }
    }
    @@media (max-width: 640px) {
        .receipt-body { padding: 20px 20px; }
        .receipt-header { padding: 28px 20px 20px; }
        .receipt-footer { padding: 20px 20px 28px; }
        .receipt-divider { padding: 0 20px; }
        .receipt-info-grid { grid-template-columns: 1fr; }
        .receipt-info-item { border-right: none; }
        .receipt-info-item:nth-child(even) { border-right: none; }
    }
</style>

<div class="receipt-page">
    <div class="receipt-actions no-print">
        <button onclick="window.print()" class="btn-print">
            <i class="fa-solid fa-print"></i> Imprimir
        </button>
        <a asp-controller="Pedido" asp-action="Details" asp-route-id="@Model.PedidoId" class="btn-back-receipt">
            <i class="fa-solid fa-arrow-left"></i> Volver al Pedido
        </a>
    </div>

    <div class="receipt-card">

        <div class="receipt-header">
            <div class="receipt-success-icon">
                <i class="fa-solid fa-check"></i>
            </div>
            <img src="~/img/LogoVallejos.png" alt="Embutidos Vallejos" class="receipt-logo" />
            <h1>Embutidos Vallejos</h1>
            <p class="receipt-subtitle">Sabor que trasciende · Cochabamba, Bolivia</p>
            <span class="receipt-type">
                <i class="fa-solid fa-file-invoice me-1"></i> Comprobante de Pago
            </span>
        </div>

        <div class="receipt-divider">
            <span class="receipt-divider-icon"><i class="fa-solid fa-scissors"></i></span>
        </div>

        <div class="receipt-body">

            <div class="receipt-info-grid">
                <div class="receipt-info-item">
                    <span class="receipt-label">Pedido #</span>
                    <span class="receipt-value" style="color:var(--accent); font-size:16px;">@Model.PedidoId.ToString("D6")</span>
                </div>
                <div class="receipt-info-item">
                    <span class="receipt-label">Fecha Pedido</span>
                    <span class="receipt-value">@Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="receipt-info-item">
                    <span class="receipt-label">Fecha de Pago</span>
                    <span class="receipt-value">@Model.FechaPago.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="receipt-info-item">
                    <span class="receipt-label">Cliente</span>
                    <span class="receipt-value">@Model.NombreCliente</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.DireccionEntrega))
                {
                    <div class="receipt-info-item full-width">
                        <span class="receipt-label"><i class="fa-solid fa-location-dot me-1"></i> Dirección de Entrega</span>
                        <span class="receipt-value">@Model.DireccionEntrega</span>
                    </div>
                }
            </div>

            <div class="receipt-payment-info">
                <div class="payment-badge @(Model.TipoPago == "QR" ? "qr-badge" : Model.TipoPago == "PayPal" ? "paypal-badge" : Model.TipoPago == "Stripe" ? "stripe-badge" : "cash-badge")">
                    <i class="@(Model.TipoPago == "QR" ? "fa-solid fa-qrcode" : Model.TipoPago == "PayPal" ? "fa-brands fa-paypal" : Model.TipoPago == "Stripe" ? "fa-brands fa-cc-stripe" : "fa-solid fa-money-bill-wave")"></i>
                    @Model.TipoPago
                </div>
                <div class="payment-status @(Model.EstadoPago == "Completado" ? "status-completed" : "status-pending")">
                    @Model.EstadoPago
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.CodigoTransaccion))
            {
                <div class="receipt-transaction">
                    <span class="receipt-label"><i class="fa-solid fa-fingerprint me-1"></i> Código de Transacción</span>
                    <span class="receipt-transaction-id">@Model.CodigoTransaccion</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ReferenciaPago))
            {
                <div class="receipt-transaction">
                    <span class="receipt-label"><i class="fa-solid fa-hashtag me-1"></i> Referencia de Pago</span>
                    <span class="receipt-transaction-id">@Model.ReferenciaPago</span>
                </div>
            }

            <div class="table-wrapper">
                <table class="receipt-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th style="text-align:center;">Cant.</th>
                            <th style="text-align:right;">Precio</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Detalles)
                        {
                            <tr>
                                <td style="font-weight:500; color:var(--text-primary);">@d.NombreProducto</td>
                                <td style="text-align:center;">
                                    <span style="background:var(--bg-elevated); border:1px solid var(--border-color); border-radius:4px; padding:2px 10px; font-size:12px; font-weight:700;">@d.Cantidad</span>
                                </td>
                                <td style="text-align:right; color:var(--text-secondary);">@d.PrecioUnitario.ToString("C", new System.Globalization.CultureInfo("es-BO"))</td>
                                <td>@d.Subtotal.ToString("C", new System.Globalization.CultureInfo("es-BO"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="receipt-total">
                    <span>TOTAL A PAGAR</span>
                    <span class="receipt-total-value">@Model.Monto.ToString("C", new System.Globalization.CultureInfo("es-BO"))</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.CodigoQR))
            {
                <div class="receipt-qr" style="margin-top:24px;">
                    <p class="qr-label"><i class="fa-solid fa-qrcode me-1"></i> Código QR de verificación</p>
                    <img src="data:image/png;base64,@Model.CodigoQR" alt="QR" class="receipt-qr-img" />
                </div>
            }

        </div>

        <div class="receipt-divider">
            <span class="receipt-divider-icon"><i class="fa-solid fa-scissors"></i></span>
        </div>

        <div class="receipt-footer">
            <p><i class="fa-solid fa-heart me-2" style="color:var(--accent); font-size:14px;"></i>¡Gracias por tu compra!</p>
            <p class="receipt-footer-text">Embutidos Vallejos — Cochabamba, Bolivia</p>
            <p class="receipt-footer-text">Este comprobante es válido como respaldo oficial de pago</p>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Trigger animación al cargar
        document.addEventListener('DOMContentLoaded', function () {
            const card = document.querySelector('.receipt-card');
            if (card) {
                setTimeout(() => { card.style.animation = 'fadeUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards'; }, 50);
            }
        });
    </script>
}

