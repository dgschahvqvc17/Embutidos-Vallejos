@model Embutidos_Vallejos.Models.DTOs.CambiarPasswordDto
@{
    ViewData["Title"] = "Cambiar Contrasena";
}

<div class="perfil-container">
    <div class="perfil-card">
        <div class="perfil-card-header">
            <div class="perfil-avatar">
                <i class="fa-solid fa-key"></i>
            </div>
            <h1>Cambiar contrasena</h1>
            <p class="perfil-role"><span class="badge-role badge-cliente"><i class="fa-regular fa-shield-halved"></i> Verifica tu identidad</span></p>
        </div>

        <form asp-action="CambiarPassword" method="post" class="perfil-form">
            <div class="perfil-form-wrap">
                <div class="form-group">
                    <label asp-for="PasswordActual" class="form-label"><i class="fa-regular fa-lock"></i> @Html.DisplayNameFor(m => m.PasswordActual)</label>
                    <div class="password-input-wrap">
                        <input asp-for="PasswordActual" class="form-control" id="pwdActual" type="password" placeholder="Tu contrasena actual" />
                        <button type="button" class="password-toggle-btn" onclick="togglePwd('pwdActual','pwdActualIcon')">
                            <i class="fa-regular fa-eye" id="pwdActualIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="PasswordActual"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PasswordActualConfirm" class="form-label"><i class="fa-regular fa-lock"></i> @Html.DisplayNameFor(m => m.PasswordActualConfirm)</label>
                    <div class="password-input-wrap">
                        <input asp-for="PasswordActualConfirm" class="form-control" id="pwdActualConfirm" type="password" placeholder="Repite tu contrasena actual" />
                        <button type="button" class="password-toggle-btn" onclick="togglePwd('pwdActualConfirm','pwdActualConfirmIcon')">
                            <i class="fa-regular fa-eye" id="pwdActualConfirmIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="PasswordActualConfirm"></span>
                </div>

                <hr class="form-divider" />

                <div class="form-group">
                    <label asp-for="NuevaPassword" class="form-label"><i class="fa-regular fa-key"></i> @Html.DisplayNameFor(m => m.NuevaPassword)</label>
                    <div class="password-input-wrap">
                        <input asp-for="NuevaPassword" class="form-control" id="pwdNueva" type="password" placeholder="Min. 6 caracteres" />
                        <button type="button" class="password-toggle-btn" onclick="togglePwd('pwdNueva','pwdNuevaIcon')">
                            <i class="fa-regular fa-eye" id="pwdNuevaIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NuevaPassword"></span>
                    <span class="form-hint"><i class="fa-regular fa-circle-info"></i> Minimo 6 caracteres</span>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmarNuevaPassword" class="form-label"><i class="fa-regular fa-key"></i> @Html.DisplayNameFor(m => m.ConfirmarNuevaPassword)</label>
                    <div class="password-input-wrap">
                        <input asp-for="ConfirmarNuevaPassword" class="form-control" id="pwdNuevaConfirm" type="password" placeholder="Repite la nueva contrasena" />
                        <button type="button" class="password-toggle-btn" onclick="togglePwd('pwdNuevaConfirm','pwdNuevaConfirmIcon')">
                            <i class="fa-regular fa-eye" id="pwdNuevaConfirmIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmarNuevaPassword"></span>
                </div>
            </div>

            <div class="perfil-card-footer">
                <a asp-action="Index" class="btn-cancel">
                    <i class="fa-regular fa-arrow-left"></i> Volver
                </a>
                <button type="submit" class="btn-submit">
                    <i class="fa-regular fa-floppy-disk"></i> Cambiar contrasena
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
