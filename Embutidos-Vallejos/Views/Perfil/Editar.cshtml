@model Embutidos_Vallejos.Models.DTOs.PerfilUpdateDto
@{
    ViewData["Title"] = "Editar Perfil";
    var email = ViewBag.Email as string;
    var userType = ViewBag.UserType as string;
}

<div class="perfil-container">
    <div class="perfil-card">
        <div class="perfil-card-header">
            <div class="perfil-avatar">
                <i class="fa-solid fa-user-pen"></i>
            </div>
            <h1>Editar mis datos</h1>
            <p class="perfil-role"><span class="badge-role badge-cliente"><i class="fa-regular fa-pen"></i> Actualiza tu informacion</span></p>
        </div>

        <form asp-action="Editar" method="post" class="perfil-form">
            <div class="perfil-form-wrap">
                <div class="row g-3">
                    <div class="col-md-6 form-group">
                        <label asp-for="Nombre" class="form-label"><i class="fa-regular fa-user"></i> @Html.DisplayNameFor(m => m.Nombre)</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Tu nombre" />
                        <span asp-validation-for="Nombre"></span>
                    </div>
                    <div class="col-md-6 form-group">
                        <label asp-for="Apellido" class="form-label"><i class="fa-regular fa-user"></i> @Html.DisplayNameFor(m => m.Apellido)</label>
                        <input asp-for="Apellido" class="form-control" placeholder="Tu apellido" />
                        <span asp-validation-for="Apellido"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="fa-regular fa-envelope"></i> Correo electronico</label>
                    <input class="form-control" value="@email" readonly disabled />
                    <span class="form-hint"><i class="fa-regular fa-circle-info"></i> El correo no se puede modificar.</span>
                </div>

                <div class="form-group">
                    <label asp-for="Telefono" class="form-label"><i class="fa-regular fa-phone"></i> @Html.DisplayNameFor(m => m.Telefono)</label>
                    <div class="phone-wrapper">
                        <span class="phone-prefix">+591</span>
                        <input asp-for="Telefono" class="form-control phone-input" id="perfilTel" placeholder="70000000" maxlength="12" />
                    </div>
                    <span asp-validation-for="Telefono"></span>
                </div>

                @if (userType == "Cliente")
                {
                    <div class="form-group">
                        <label asp-for="Direccion" class="form-label"><i class="fa-regular fa-location-dot"></i> @Html.DisplayNameFor(m => m.Direccion)</label>
                        <textarea asp-for="Direccion" class="form-control" rows="3" placeholder="Calle, numero, zona..."></textarea>
                        <span asp-validation-for="Direccion"></span>
                    </div>
                }
            </div>

            <div class="perfil-card-footer">
                <a asp-action="Index" class="btn-cancel">
                    <i class="fa-regular fa-arrow-left"></i> Volver
                </a>
                <button type="submit" class="btn-submit">
                    <i class="fa-regular fa-floppy-disk"></i> Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
