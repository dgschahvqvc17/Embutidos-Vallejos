@model List<Embutidos_Vallejos.Models.DTOs.ProductoDto>
@{
    ViewData["Title"] = "Productos";
    var categorias = ViewBag.Categorias as List<Embutidos_Vallejos.Models.DTOs.CategoriaDto>;
    var esCatalogo = ViewBag.Catalogo == true;
}

<div class="page-header">
    <h1 class="page-title">Nuestros Productos</h1>
    <p class="page-subtitle">Embutidos artesanales de la mejor calidad</p>
</div>

<div class="product-carousel">
    <div class="carousel-track">
        <div class="carousel-slide">
            <img src="~/img/chorizo.jpg" alt="Chorizo Artesanal">
            <div class="carousel-overlay">
                <h3>Chorizo Artesanal</h3>
                <p>El sabor tradicional de siempre</p>
            </div>
        </div>
        <div class="carousel-slide">
            <img src="~/img/embutido1.jpg" alt="Embutidos Premium">
            <div class="carousel-overlay">
                <h3>Embutidos Premium</h3>
                <p>Calidad superior en cada pieza</p>
            </div>
        </div>
        <div class="carousel-slide">
            <img src="~/img/jamon.jfif" alt="Jamon Especial">
            <div class="carousel-overlay">
                <h3>Jamon Especial</h3>
                <p>Curado lentamente para un sabor unico</p>
            </div>
        </div>
        <div class="carousel-slide">
            <img src="~/img/jamon2.jfif" alt="Jamon Selecto">
            <div class="carousel-overlay">
                <h3>Jamon Selecto</h3>
                <p>Ideal para tus mejores ocasiones</p>
            </div>
        </div>
        <div class="carousel-slide">
            <img src="~/img/salchichas.jpg" alt="Salchichas">
            <div class="carousel-overlay">
                <h3>Salchichas</h3>
                <p>Practicas y deliciosas para cualquier momento</p>
            </div>
        </div>
    </div>
    <button class="carousel-prev" aria-label="Anterior"><i class="fa-solid fa-chevron-left"></i></button>
    <button class="carousel-next" aria-label="Siguiente"><i class="fa-solid fa-chevron-right"></i></button>
    <div class="carousel-dots">
        <button class="carousel-dot active" data-index="0" aria-label="Slide 1"></button>
        <button class="carousel-dot" data-index="1" aria-label="Slide 2"></button>
        <button class="carousel-dot" data-index="2" aria-label="Slide 3"></button>
        <button class="carousel-dot" data-index="3" aria-label="Slide 4"></button>
        <button class="carousel-dot" data-index="4" aria-label="Slide 5"></button>
    </div>
</div>

<div class="category-tabs mb-4">
    <a asp-action="Index" asp-route-catalogo="@(esCatalogo ? "true" : "false")" class="cat-tab @(ViewBag.CategoriaActual == null ? "active" : "")">Todos</a>
    @if (categorias != null)
    {
        @foreach (var cat in categorias)
        {
            <a asp-action="Index" asp-route-categoriaId="@cat.CategoriaId" asp-route-catalogo="@(esCatalogo ? "true" : "false")"
               class="cat-tab @(ViewBag.CategoriaActual == cat.CategoriaId ? "active" : "")">
                @cat.Nombre
            </a>
        }
    }
</div>

<div class="row g-4">
    @foreach (var prod in Model)
    {
        <div class="col-lg-3 col-md-4 col-6 animate-fade-up">
            <div class="product-card glass-panel glow-border" data-id="@prod.ProductoId">
                <div class="product-img-wrapper">
                    <img src="@(prod.Imagen ?? "/img/LogoVallejos.png")" alt="@prod.Nombre" class="product-img" />
                    @if (prod.StockBajo && prod.Stock > 0)
                    {
                        <span class="product-badge badge-warning">Pocas unidades</span>
                    }
                    else if (prod.Stock == 0)
                    {
                        <span class="product-badge badge-danger">Agotado</span>
                    }
                </div>
                <div class="product-info">
                    <span class="product-category">@prod.NombreCategoria</span>
                    <h3 class="product-name glow-text">@prod.Nombre</h3>
                    <p class="product-price">@prod.PrecioVenta.ToString("C", new System.Globalization.CultureInfo("es-BO"))</p>
                    <div class="product-stock-info">
                        @if (prod.Stock > 0)
                        {
                            <span class="stock-indicator @(prod.StockBajo ? "stock-low" : "stock-ok")">
                                <i class="fa-solid @(prod.StockBajo ? "fa-circle-exclamation" : "fa-circle")"></i>
                                @prod.Stock en stock
                            </span>
                        }
                        else
                        {
                            <span class="stock-indicator stock-out">
                                <i class="fa-solid fa-circle"></i> Sin stock
                            </span>
                        }
                    </div>
                    @if (!esCatalogo && prod.Stock > 0)
                    {
                        <div class="d-flex gap-2">
                            <div class="qty-selector-sm">
                                <button type="button" class="qty-sm-btn" onclick="changeGridQty(@prod.ProductoId, -1, this)">
                                    <i class="fa-solid fa-minus"></i>
                                </button>
                                <input type="number" class="product-qty" value="1" min="1" max="@prod.Stock" readonly id="qty-@prod.ProductoId" />
                                <button type="button" class="qty-sm-btn" onclick="changeGridQty(@prod.ProductoId, 1, this)">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                            </div>
                            <button class="btn-premium btn-add-cart" onclick="addToCart(@prod.ProductoId, this)">
                                <i class="fa-solid fa-cart-plus"></i> <span>Agregar</span>
                            </button>
                        </div>
                    }
                    else if (!esCatalogo)
                    {
                        <button class="btn-disabled" disabled>
                            <i class="fa-solid fa-ban"></i> Agotado
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function changeGridQty(productoId, delta, btn) {
            const input = document.getElementById('qty-' + productoId);
            let val = parseInt(input.value) + delta;
            const max = parseInt(input.max);
            if (val < 1) val = 1;
            if (val > max) val = max;
            input.value = val;
        }

        function addToCart(productoId, btn) {
            const qty = document.getElementById('qty-' + productoId).value;
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.style.opacity = '0.7';
            fetch('@Url.Action("Agregar", "Carrito")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `productoId=${productoId}&cantidad=${qty}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    btn.innerHTML = '<i class="fa-solid fa-check"></i> <span>Agregado</span>';
                    btn.style.background = 'linear-gradient(135deg, #16a34a 0%, #22c55e 100%)';
                    btn.style.opacity = '1';
                    setTimeout(() => {
                        btn.innerHTML = originalHtml;
                        btn.style.background = '';
                        btn.style.opacity = '';
                        btn.disabled = false;
                    }, 1800);
                    updateCartCount();
                } else {
                    alert(data.message);
                    btn.innerHTML = originalHtml;
                    btn.style.opacity = '';
                    btn.disabled = false;
                }
            });
        }

        function updateCartCount() {
            fetch('@Url.Action("ObtenerConteo", "Carrito")')
                .then(r => r.json())
                .then(data => {
                    const badge = document.getElementById('cart-count');
                    if (badge) {
                        badge.textContent = data.count;
                        badge.style.display = data.count > 0 ? 'flex' : 'none';
                    }
                    const fab = document.getElementById('cart-fab');
                    if (fab) {
                        fab.style.display = data.count > 0 ? 'flex' : 'none';
                        document.getElementById('cart-fab-count').textContent = data.count;
                    }
                });
        }

        (function() {
            const track = document.querySelector('.carousel-track');
            const slides = document.querySelectorAll('.carousel-slide');
            const prev = document.querySelector('.carousel-prev');
            const next = document.querySelector('.carousel-next');
            const dots = document.querySelectorAll('.carousel-dot');

            if (!track || slides.length === 0) return;

            let currentIndex = 0;
            const totalSlides = slides.length;
            let autoplayInterval;
            let touchStartX = 0;
            let touchEndX = 0;

            function updateCarousel() {
                track.style.transform = 'translateX(-' + currentIndex * 100 + '%)';
                dots.forEach(function(dot, i) {
                    dot.classList.toggle('active', i === currentIndex);
                });
            }

            function nextSlide() {
                currentIndex = (currentIndex + 1) % totalSlides;
                updateCarousel();
            }

            function prevSlide() {
                currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
                updateCarousel();
            }

            function startAutoplay() {
                stopAutoplay();
                autoplayInterval = setInterval(nextSlide, 4200);
            }

            function stopAutoplay() {
                if (autoplayInterval) clearInterval(autoplayInterval);
            }

            if (next) next.addEventListener('click', function() { nextSlide(); startAutoplay(); });
            if (prev) prev.addEventListener('click', function() { prevSlide(); startAutoplay(); });

            dots.forEach(function(dot) {
                dot.addEventListener('click', function() {
                    currentIndex = parseInt(dot.getAttribute('data-index'));
                    updateCarousel();
                    startAutoplay();
                });
            });

            const carousel = document.querySelector('.product-carousel');
            if (carousel) {
                carousel.addEventListener('mouseenter', stopAutoplay);
                carousel.addEventListener('mouseleave', startAutoplay);
                carousel.addEventListener('touchstart', function(e) {
                    touchStartX = e.changedTouches[0].screenX;
                    stopAutoplay();
                }, { passive: true });
                carousel.addEventListener('touchend', function(e) {
                    touchEndX = e.changedTouches[0].screenX;
                    var diff = touchStartX - touchEndX;
                    if (Math.abs(diff) > 50) {
                        if (diff > 0) nextSlide(); else prevSlide();
                    }
                    startAutoplay();
                });
            }

            startAutoplay();
        })();

        document.addEventListener('DOMContentLoaded', updateCartCount);
    </script>

}

@if (!esCatalogo)
{
    <a id="cart-fab" asp-controller="Carrito" asp-action="Index" class="cart-fab">
        <i class="fa-solid fa-bag-shopping"></i>
        <span>Ver Carrito</span>
        <span id="cart-fab-count" class="cart-fab-badge">0</span>
    </a>
}
